# Server
PORT=5000
CORS_ORIGIN=http://localhost:5173
# Used to build links inside emails (e.g. the password reset link)
FRONTEND_URL=http://localhost:5173

# MongoDB Atlas - get this from Atlas > Database > Connect > Drivers
# Example: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/sachivalayam_portal?retryWrites=true&w=majority
MONGODB_URI=

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=8h

# Email (SMTP) - leave blank to just log notifications to console instead of sending
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Sachivalayam Portal <no-reply@govportal.local>"

# SMS (placeholder - wire up Twilio or any SMS gateway here)
SMS_API_KEY=
SMS_API_URL=

# Admin bootstrap (created automatically on first run if no admin exists)
ADMIN_NAME=Portal Admin
ADMIN_EMAIL=admin@govportal.local
ADMIN_PHONE=9999999999
ADMIN_PASSWORD=Admin@123
